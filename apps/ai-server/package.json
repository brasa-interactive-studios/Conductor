{
  "name": "@apps/ai-server",
  "version": "0.1.0",
  "private": true,
  "type": "commonjs",
  "main": "dist/server.js",
  "scripts": {
    "dev": "pnpm --filter @vscode-ai/shared build && tsx watch src/server.ts",
    "build": "pnpm --filter @vscode-ai/shared build && tsc -p tsconfig.json",
    "start": "pnpm --filter @vscode-ai/shared build && node dist/server.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "echo \"No tests yet for @apps/ai-server\""
  },
  "dependencies": {
    "@fastify/cors": "^10.0.1",
    "@fastify/websocket": "^11.0.2",
    "@vscode-ai/shared": "workspace:*",
    "fastify": "^5.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}